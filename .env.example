# Copy to .env and fill in your values
# (Never commit .env to version control)

# Required: Portainer base URL (no trailing slash)
PORTAINER_URL=https://portainer.example.com

# Authentication — use token OR username/password
PORTAINER_TOKEN=ptr_xxxxxxxxxxxx

# PORTAINER_USERNAME=admin
# PORTAINER_PASSWORD=changeme

# Set to true to skip TLS certificate verification (not recommended for production)
PORTAINER_TLS_SKIP_VERIFY=false
